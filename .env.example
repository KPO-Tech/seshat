# Nexus Engine — environment variables
# Copy this file to .env and fill in the values you need.
# You only need to set the providers you actually use.
# At least one LLM provider is required.

# ─── LLM Providers ────────────────────────────────────────────────────────────

# Anthropic (Claude models) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT models + DALL-E + TTS + Whisper) — https://platform.openai.com
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com
GOOGLE_API_KEY=

# Mistral AI — https://console.mistral.ai
MISTRAL_API_KEY=

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenRouter (access to many models with one key) — https://openrouter.ai
OPENROUTER_API_KEY=

# Z.ai — https://z.ai
Z_AI_API_KEY=

# Ollama (local models, no key needed — just start `ollama serve`)
# OLLAMA_HOST=http://localhost:11434

# ─── Jupyter (notebook tools) ─────────────────────────────────────────────────
# Required for notebook_execute, notebook_run, notebook_kernel.
# Start Jupyter: jupyter server --no-browser
# The token appears in the startup output.

JUPYTER_SERVER_URL=http://localhost:8888
JUPYTER_TOKEN=

# ─── Social tools ─────────────────────────────────────────────────────────────

# dev.to — required only for devto_publish (read tools work without a key)
# Get your key at: https://dev.to/settings/extensions
DEV_TO_API_KEY=

# Reddit — required for reddit_search, reddit_posts (stub, not yet implemented)
# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Twitter / X — required for twitter_search and twitter_tweet (stub)
# Get tokens at: https://developer.twitter.com
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ─── Notification tools ───────────────────────────────────────────────────────

# Slack — set either the webhook URL (simple) or the bot token (richer)
# Webhook: Slack app → Incoming Webhooks → Add New Webhook to Workspace
# Bot token: Slack app → OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHAN=#general

# Discord — set either the webhook URL (simple) or the bot token (richer)
# Webhook: Discord server → Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# Telegram — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email via SMTP — works with Gmail (app passwords), SendGrid, Postmark, SES, etc.
# Gmail: enable 2FA → create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# WhatsApp Business Cloud API (stub, not yet implemented)
# Requires a Meta Business account and an approved WhatsApp Business app.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─── Search backends ──────────────────────────────────────────────────────────

# SearXNG — self-hosted privacy-respecting metasearch engine
# Leave blank to use the DuckDuckGo backend (no key required).
SEARXNG_URL=
SEARXNG_USERNAME=
SEARXNG_PASSWORD=

# Exa — AI-native search API — https://exa.ai
EXA_API_KEY=

# Tavily — search API optimised for agents — https://tavily.com
TAVILY_API_KEY=

# ─── Optional services ────────────────────────────────────────────────────────

# Docling — PDF-to-Markdown conversion service
# Run locally: docker run -p 5001:5001 ds4sd/docling-serve
# DOCLING_URL=http://localhost:5001
